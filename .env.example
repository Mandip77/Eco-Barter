# ==============================================================================
# EcoBarter Environment Configuration — EXAMPLE
# Copy this file to .env and fill in real values. Never commit .env to git.
# ==============================================================================

# --- Databases ---
POSTGRES_USER=ecouser
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=ecobarter_db

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_random_password
MONGO_DB=ecobarter_catalog

# --- Real-Time Messaging & Cache ---
NATS_URL=nats://nats:4222
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NATS_AUTH_TOKEN=CHANGE_ME_strong_random_token
REDIS_URL=redis://redis:6379

# --- Real-Time WebSocket Engine (Centrifugo) ---
CENTRIFUGO_ADMIN_PASSWORD=CHANGE_ME_strong_random_password
CENTRIFUGO_SECRET=CHANGE_ME_min_32_char_random_string
CENTRIFUGO_API_KEY=CHANGE_ME_min_32_char_random_string

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_min_64_char_random_string_do_not_use_in_prod

# --- Service Internal URLs (auto-constructed from above) ---
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
POSTGRES_DSN=host=postgres user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} dbname=${POSTGRES_DB} port=5432 sslmode=disable
CATALOG_MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017

# --- Frontend ---
VITE_API_BASE_URL=/api/v1
