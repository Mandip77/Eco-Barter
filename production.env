# ==============================================================================
# EcoBarter PRODUCTION Environment Configuration
# ==============================================================================
# IMPORTANT: Copy this file to .env on your server and change the values!

# --- Deployment ---
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@example.com

# --- Databases ---
POSTGRES_USER=ecouser
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_STRONG
POSTGRES_DB=ecobarter_db

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_TO_SOMETHING_STRONG
MONGO_DB=ecobarter_catalog

# --- Real-Time Messaging & Cache ---
NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379

# --- Real-Time WebSocket Engine (Centrifugo) ---
CENTRIFUGO_ADMIN_PASSWORD=CHANGE_ME_STRONG
CENTRIFUGO_SECRET=CHANGE_ME_SUPER_SECRET
CENTRIFUGO_API_KEY=CHANGE_ME_SUPER_SECRET

# --- Security ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# --- Service Internal URLs (Leave these as is) ---
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
POSTGRES_DSN=host=postgres user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} dbname=${POSTGRES_DB} port=5432 sslmode=disable
CATALOG_MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017

# --- Frontend ---
VITE_API_BASE_URL=/api/v1
